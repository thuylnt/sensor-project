  },
  {
    "id": "fn_status_format",
    "type": "function",
    "z": "tab_pdr",
    "name": "format status",
    "func": "var s = msg.payload || {};\nvar up = s.uptime_s || 0;\nvar h = Math.floor(up/3600);\nvar m = Math.floor((up%3600)/60);\nvar sec = up % 60;\nvar pad = function(n){return n < 10 ? '0'+n : ''+n;};\nvar heap_kb = Math.round((s.free_heap || 0) / 1024);\nmsg.payload = 'Up ' + h + ':' + pad(m) + ':' + pad(sec)\n  + '  •  RSSI ' + (s.rssi !== undefined ? s.rssi : '?') + ' dBm'\n  + '  •  Heap ' + heap_kb + ' KB'\n  + '  •  Offline ' + (s.offline_records || 0);\nreturn msg;",
    "outputs": 1,
    "x": 320,
    "y": 480,
    "wires": [["ui_status"]]
  },
