    "width": "3",
    "height": "4",
    "format": "<canvas id=\"compass\" width=\"160\" height=\"160\" style=\"display:block;margin:auto\"></canvas>\n<script>\n(function(scope){\n  var canvas = document.getElementById('compass');\n  var ctx = canvas.getContext('2d');\n  var heading = 0;\n  function draw(){\n    ctx.clearRect(0,0,160,160);\n    var cx = 80, cy = 80, r = 68;\n    ctx.strokeStyle = '#999'; ctx.lineWidth = 2;\n    ctx.beginPath(); ctx.arc(cx, cy, r, 0, 2*Math.PI); ctx.stroke();\n    for (var a = 0; a < 360; a += 30){\n      var rad = a * Math.PI / 180;\n      var tickLen = (a % 90 === 0) ? 10 : 5;\n      ctx.strokeStyle = '#aaa'; ctx.lineWidth = 1.5;\n      ctx.beginPath();\n      ctx.moveTo(cx + (r - tickLen) * Math.sin(rad), cy - (r - tickLen) * Math.cos(rad));\n      ctx.lineTo(cx + r * Math.sin(rad), cy - r * Math.cos(rad));\n      ctx.stroke();\n    }\n    ctx.font = 'bold 14px sans-serif';\n    ctx.fillStyle = '#666';\n    ctx.textAlign = 'center'; ctx.textBaseline = 'middle';\n    ctx.fillText('N', cx, cy - r + 14);\n    ctx.fillText('E', cx + r - 14, cy);\n    ctx.fillText('S', cx, cy + r - 14);\n    ctx.fillText('W', cx - r + 14, cy);\n    ctx.save(); ctx.translate(cx, cy); ctx.rotate(heading * Math.PI / 180);\n    ctx.fillStyle = '#d32f2f';\n    ctx.beginPath();\n    ctx.moveTo(0, -r + 20); ctx.lineTo(-9, 0); ctx.lineTo(0, 8); ctx.lineTo(9, 0); ctx.closePath(); ctx.fill();\n    ctx.fillStyle = '#bbb';\n    ctx.beginPath();\n    ctx.moveTo(0, r - 20); ctx.lineTo(-9, 0); ctx.lineTo(0, -8); ctx.lineTo(9, 0); ctx.closePath(); ctx.fill();\n    ctx.fillStyle = '#333';\n    ctx.beginPath(); ctx.arc(0, 0, 5, 0, 2*Math.PI); ctx.fill();\n    ctx.restore();\n    ctx.font = '13px sans-serif';\n    ctx.fillStyle = '#333';\n    ctx.fillText(heading.toFixed(0) + '°', cx, cy + r + 10);\n    ctx.textAlign = 'left'; ctx.textBaseline = 'alphabetic';\n  }\n  draw();\n  scope.$watch('msg.payload', function(p){\n    if (!p) return;\n    var h = (typeof p.heading_deg === 'number') ? p.heading_deg : p.heading;\n    if (typeof h !== 'number') return;\n    heading = h;\n    draw();\n  });\n})(scope);\n</script>",
